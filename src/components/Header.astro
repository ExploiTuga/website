---
import { navigation, socialLinks } from '../data/navigation';
---

<header class="header">
  <div class="container header-container">
    <a href="/" class="logo" aria-label="exploiTuga - Homepage">
      <span class="logo-text">exploiTuga</span>
    </a>
    
    <nav class="nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navigation.map((item) => (
          <li>
            <a href={item.href} class="nav-link">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    
    <div class="header-actions">
      {socialLinks.map((item) => (
        <a 
          href={item.href} 
          class="social-link" 
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
          aria-label={item.label}
        >
          {item.label}
        </a>
      ))}
    </div>
    
    <button class="mobile-menu-button" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    height: var(--header-height);
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  
  .logo {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text);
  }
  
  .logo-text {
    background: linear-gradient(90deg, var(--color-primary), #00ff00);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  
  .nav-list {
    display: flex;
    gap: var(--space-6);
    list-style: none;
  }
  
  .nav-link {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }
  
  .nav-link:hover {
    color: var(--color-text);
  }
  
  .header-actions {
    display: flex;
    gap: var(--space-4);
  }
  
  .social-link {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    transition: color var(--transition-fast);
  }
  
  .social-link:hover {
    color: var(--color-primary);
  }
  
  .mobile-menu-button {
    display: none;
  }
  
  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
    position: relative;
    transition: var(--transition-fast);
  }
  
  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
  }
  
  .hamburger::before {
    top: -8px;
  }
  
  .hamburger::after {
    top: 8px;
  }
  
  /* Mobile styles */
  @media (max-width: 768px) {
    .nav {
      display: none;
    }
    
    .mobile-menu-button {
      display: block;
    }
    
    .header-actions {
      display: none;
    }
  }
</style>