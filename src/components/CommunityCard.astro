---
interface Props {
  title: string;
  description: string;
  icon?: string;
  link?: string;
}

const { title, description, icon, link } = Astro.props;
---

<div class="community-card">
  <div class="community-card-content">
    {icon && <div class="community-card-icon">{icon}</div>}
    <h3 class="community-card-title">{title}</h3>
    <p class="community-card-description">{description}</p>
    {link && (
      <a 
        href={link} 
        class="community-card-link"
        target={link.startsWith('http') ? '_blank' : undefined}
        rel={link.startsWith('http') ? 'noopener noreferrer' : undefined}
      >
        Saiba mais
      </a>
    )}
  </div>
</div>

<style>
  .community-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-6);
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }
  
  .community-card:hover {
    border-color: var(--color-border-hover);
    background-color: var(--color-surface-hover);
  }
  
  .community-card-icon {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }
  
  .community-card-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }
  
  .community-card-description {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }
  
  .community-card-link {
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  
  .community-card-link:hover {
    color: var(--color-primary-hover);
  }
</style>