---
interface Props {
  title: string;
  description: string;
  category: string;
  date?: string;
}

const { title, description, category, date } = Astro.props;
---

<article class="research-card">
  <div class="research-card-content">
    <p class="research-card-category">{category}</p>
    <h3 class="research-card-title">{title}</h3>
    <p class="research-card-description">{description}</p>
    {date && <time class="research-card-date">{date}</time>}
  </div>
</article>

<style>
  .research-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-6);
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }
  
  .research-card:hover {
    border-color: var(--color-border-hover);
    background-color: var(--color-surface-hover);
  }
  
  .research-card-category {
    font-size: 0.75rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }
  
  .research-card-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }
  
  .research-card-description {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
  }
  
  .research-card-date {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    margin-top: var(--space-4);
  }
</style>