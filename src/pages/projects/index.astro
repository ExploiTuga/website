---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';
---

<Layout 
  title="Projetos — exploiTuga"
  description="Projetos de cybersecurity open source da comunidade exploiTuga."
>
  <Header />
  
  <main class="main">
    <section class="section">
      <div class="container">
        <h1 class="page-title">Projetos</h1>
        <p class="page-description">
          Ferramentas e projetos de cybersecurity desenvolvidos pela comunidade.
        </p>
      </div>
    </section>
    
    <section class="section">
      <div class="container">
        {projects.length > 0 ? (
          <div class="grid">
            {projects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <p>Projetos em breve. Junta-te à nossa comunidade para mais informações.</p>
          </div>
        )}
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .main {
    min-height: calc(100vh - var(--header-height));
    padding-top: var(--space-16);
  }
  
  .page-title {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }
  
  .page-description {
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }
  
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-12);
  }
  
  .empty-state {
    text-align: center;
    padding: var(--space-20) 0;
    color: var(--color-text-muted);
  }
</style>