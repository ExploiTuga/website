---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout 
  title="Sobre — exploiTuga"
  description="Sobre a comunidade portuguesa de cybersecurity exploiTuga."
>
  <Header />
  
  <main class="main">
    <section class="section">
      <div class="container">
        <h1 class="page-title">Sobre o exploiTuga</h1>
      </div>
    </section>
    
    <section class="section">
      <div class="container">
        <div class="about-content">
          <div class="about-section">
            <h2 class="about-heading">O que é</h2>
            <p class="about-text">
              O exploiTuga é uma comunidade portuguesa de cybersecurity, hacking ético e segurança informática.
              Reunimos pessoas interessadas em ethical hacking, penetration testing, security research, OSINT,
              threat intelligence, CTFs e desenvolvimento de ferramentas open source.
            </p>
          </div>
          
          <div class="about-section">
            <h2 class="about-heading">Missão</h2>
            <p class="about-text">
              Promover a educação e partilha de conhecimento em cybersecurity em Portugal,
              contribuindo para um ecossistema mais seguro através de ferramentas open source
              e investigação de segurança.
            </p>
          </div>
          
          <div class="about-section">
            <h2 class="about-heading">Áreas de Interesse</h2>
            <ul class="about-list">
              <li>Cybersecurity</li>
              <li>Ethical Hacking</li>
              <li>Penetration Testing</li>
              <li>Security Research</li>
              <li>OSINT</li>
              <li>Threat Intelligence</li>
              <li>CTFs</li>
              <li>Desenvolvimento de ferramentas de segurança</li>
              <li>Open Source</li>
              <li>Partilha de conhecimento</li>
            </ul>
          </div>
          
          <div class="about-section">
            <h2 class="about-heading">Filosofia</h2>
            <p class="about-text">
              Acreditamos em código aberto, colaboração e transparência. Todos os nossos projetos
              são open source e encorajamos a participação da comunidade.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .main {
    min-height: calc(100vh - var(--header-height));
    padding-top: var(--space-16);
  }
  
  .page-title {
    font-size: 2.5rem;
    margin-bottom: var(--space-8);
    color: var(--color-text);
  }
  
  .about-content {
    max-width: 700px;
    margin-top: var(--space-8);
  }
  
  .about-section {
    margin-bottom: var(--space-12);
  }
  
  .about-heading {
    font-size: 1.5rem;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }
  
  .about-text {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 1.125rem;
  }
  
  .about-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  
  .about-list li {
    color: var(--color-text-muted);
    padding: var(--space-2) 0;
  }
</style>