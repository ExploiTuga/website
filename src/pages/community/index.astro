---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
---

<Layout 
  title="Comunidade — exploiTuga"
  description="Junta-te à comunidade portuguesa de cybersecurity exploiTuga."
>
  <Header />
  
  <main class="main">
    <section class="section">
      <div class="container">
        <h1 class="page-title">Comunidade</h1>
        <p class="page-description">
          A comunidade exploiTuga reúne entusiastas e profissionais de cybersecurity em Portugal.
        </p>
      </div>
    </section>
    
    <section class="section">
      <div class="container">
        <div class="content-grid">
          <div class="content-card">
            <h2 class="card-title">Quem somos</h2>
            <p class="card-text">
              Somos uma comunidade aberta dedicada ao estudo e desenvolvimento de segurança informática.
              Acreditamos na partilha de conhecimento e na colaboração entre membros.
            </p>
          </div>
          
          <div class="content-card">
            <h2 class="card-title">O que fazemos</h2>
            <p class="card-text">
              Desenvolvemos ferramentas open source, publicamos artigos de security research,
              participamos em CTFs, organizamos eventos e contribuímos para a segurança digital.
            </p>
          </div>
          
          <div class="content-card">
            <h2 class="card-title">Como participar</h2>
            <p class="card-text">
              Junta-te ao nosso Discord para discussões técnicas, colabora nos nossos projetos GitHub
              e participa nos eventos que organizamos.
            </p>
          </div>
        </div>
      </div>
    </section>
    
    <section class="section section--discord">
      <div class="container">
        <div class="discord-content">
          <h2 class="discord-title">Junta-te ao Discord</h2>
          <p class="discord-description">
            A melhor forma de entrar em contacto connosco é através do nosso servidor Discord.
          </p>
          <Button href="PLACEHOLDER_DISCORD_URL" external>Juntar-me à Comunidade</Button>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .main {
    min-height: calc(100vh - var(--header-height));
    padding-top: var(--space-16);
  }
  
  .page-title {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }
  
  .page-description {
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }
  
  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-12);
  }
  
  .content-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-6);
  }
  
  .card-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }
  
  .card-text {
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  
  .section--discord {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-top: var(--space-16);
    padding: var(--space-16) 0;
  }
  
  .discord-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .discord-title {
    font-size: 2rem;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }
  
  .discord-description {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }
</style>